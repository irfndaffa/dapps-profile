# Admin area (hidden link in the footer, or visit /admin directly)

# Password required to log into /admin. Choose a strong, unique value.
ADMIN_PASSWORD=

# Secret used to sign the admin session cookie. Falls back to ADMIN_PASSWORD
# if unset, but setting a separate long random value is recommended.
ADMIN_SESSION_SECRET=

# GitHub personal access token with write (contents) access to this repo.
# Used to commit admin edits (about/experience/skills/contact/photo), which
# triggers a redeploy on Vercel.
GITHUB_TOKEN=

# Defaults to irfndaffa/dapps-profile and the main branch — only set these
# if you fork/rename the repo or deploy from a different branch.
GITHUB_REPO=
GITHUB_BRANCH=
